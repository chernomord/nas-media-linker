# Copy to ops/dsm/nas-linker.env on DSM and fill real values.
# Do not commit the filled file.
UX_STATE_DB_PATH="/volume1/scripts/nas-linker/data/ux-state.sqlite"

PLEX_DISCOVER_URL="https://discover.provider.plex.tv"
PLEX_DISCOVER_TOKEN="replace_me"
PLEX_DISCOVER_PRODUCT="Plex Web"
PLEX_DISCOVER_VERSION="4.147.1"
PLEX_DISCOVER_CLIENT_ID="replace_me"
PLEX_DISCOVER_PLATFORM="Safari"
PLEX_DISCOVER_PLATFORM_VERSION="26.2"
PLEX_DISCOVER_FEATURES="external-media,indirect-media,hub-style-list"
PLEX_DISCOVER_MODEL="bundled"
PLEX_DISCOVER_DEVICE="OSX"
PLEX_DISCOVER_DEVICE_RESOLUTION="1512x982"
PLEX_DISCOVER_PROVIDER_VERSION="7.2"
PLEX_DISCOVER_TEXT_FORMAT="plain"
PLEX_DISCOVER_DRM="fairplay"
PLEX_DISCOVER_LANGUAGE="en"

OMDB_API_KEY="replace_me"

# Current execution note:
# - Node executor is the only supported execution path for all operations.
# - UX_STATE_DB_PATH controls the sqlite file for low-sensitivity UX state.

# v1.1 NAS-hosted mode should add explicit app auth in helper or proxy.
# Keep hashed credentials outside the repo.
# APP_AUTH_PASSWORD_HASH must be wrapped in single quotes because it contains '$'.
# Example:
# APP_AUTH_USER="replace_me"
# APP_AUTH_PASSWORD_HASH='scrypt$16384$8$1$<salt>$<hash>'
